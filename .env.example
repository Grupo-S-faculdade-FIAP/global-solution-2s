# ═══════════════════════════════════════════════════════════════════════════════
# Environment Configuration — Global Solutions
# 
# Copy this file to .env and fill in the values.
# .env is NOT committed to git (see .gitignore)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Project ──────────────────────────────────────────────────────────────────
PROJECT_NAME=Global Solutions — Environmental Intelligence
ENVIRONMENT=development
DEBUG=true

# ─── Dashboard (montado em / na porta 8000 via make demo) ─────────────────────
# true = gráficos simulados se API offline; botões de dev visíveis (padrão)
# false = exige FastAPI; oculta simulação/YOLO amostra
# MOUNT_DASHBOARD=true  # true = Flask local (make demo); false = FastAPI UI na Lambda
# BFF_INPROCESS=true    # local uvicorn: BFF chama FastAPI in-process (Lambda: automático)
DEMO_MODE=true

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:8000
# Origens extras (staging/prod) — mescladas com ALLOWED_ORIGINS via get_allowed_origins()
# CORS_EXTRA_ORIGINS=https://dashboard.example.com,https://api.example.com

# ─── AWS X-Ray (Lambda) ─────────────────────────────────────────────────────
# true = tracing distribuído na Lambda; false = desabilita (menos latência em dev)
XRAY_ENABLED=true

# ─── AWS ──────────────────────────────────────────────────────────────────────
# For local development with real AWS, set credentials below.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:<account_id>:rain-alerts
# false = não publica mesmo com ARN (útil em dev local)
SNS_ENABLED=true
SNS_ALERT_SUBJECT=Rain Alert — Storm Detected
# Limite de inscrições no tópico SNS e alertas por e-mail por dia (UTC)
SNS_MAX_SUBSCRIBERS=20
SNS_MAX_ALERTS_PER_EMAIL_DAY=3
# Cooldown entre alertas SNS da mesma região NASA (minutos; cron a cada 15 min)
SNS_REGION_COOLDOWN_MINUTES=60
# Tabela DynamoDB para limite diário por e-mail e cooldown regional (produção)
DYNAMODB_TABLE_SNS_RATE_LIMIT=sns_rate_limits
# Amazon SES — entrega por destinatário com filtro geo/rate limit (recomendado).
# Vazio = fallback sns.publish(TopicArn) — todos os inscritos confirmados recebem.
# SES_FROM_EMAIL=alerts@example.com
# SES_ENABLED=true

# ─── IoT (ESP32) ──────────────────────────────────────────────────────────────
# true = leituras simuladas no dashboard (sem hardware); false = DynamoDB iot_readings
IOT_USE_MOCK=true

# ─── DynamoDB ─────────────────────────────────────────────────────────────────
DYNAMODB_WEATHER_TABLE=weather_metrics
DYNAMODB_STORM_TABLE=storm_detections
DYNAMODB_RISK_TABLE=risk_predictions
DYNAMODB_IOT_TABLE=iot_readings
# Tabela de alertas CV e analytics (alert_type + timestamp)
DYNAMODB_TABLE_ALERTS=alerts

# ─── S3 ───────────────────────────────────────────────────────────────────────
S3_BUCKET_MODELS=model-artifacts
S3_BUCKET_IMAGES=satellite-images-gs2
S3_BUCKET_OUTPUTS=output-detections

# ─── Open-Meteo API ───────────────────────────────────────────────────────────
# Free weather API (no credentials required)
OPENMETEO_API_URL=https://api.open-meteo.com/v1/forecast
OPENMETEO_TIMEZONE=auto
# Rate limit outbound calls (no API token) — dev local only; Lambda is exempt
EXTERNAL_API_RATE_LIMIT_ENABLED=true
EXTERNAL_API_RATE_LIMIT_PER_HOUR=20
# EXTERNAL_API_RATE_LIMIT_STORE_PATH=data/demo/external_api_rate_limits.json

# ─── Weather Ingestion (Lambda) ───────────────────────────────────────────────
# Locations format: lat1,lon1,name1,lat2,lon2,name2,...
# Default: São Paulo, Rio, Brasília, Porto Alegre, Palmas
WEATHER_LOCATIONS=-23.5505,-46.6333,-22.9068,-43.1729,-15.8267,-47.8711,-30.0346,-51.2177,-9.9794,-49.8623

# Data retention in DynamoDB (days)
WEATHER_RETENTION_DAYS=90

# ─── Computer Vision (YOLO) ───────────────────────────────────────────────────
YOLO_MODEL_PATH=s3://satellite-images-gs2/models/best.pt
YOLO_MODEL_S3_KEY=models/best.pt

# Confidence threshold for detections (0.0-1.0)
YOLO_CONFIDENCE_THRESHOLD=0.55

# Input image size for YOLO
YOLO_INPUT_SIZE=640

# Model data retention (days)
YOLO_MODEL_RETENTION_DAYS=30

# ─── Machine Learning (Risk Prediction) ────────────────────────────────────
# Local path to trained ML model
ML_MODEL_PATH=models/risk_predictor.pkl

# Risk score thresholds (0.0-1.0)
# HIGH risk if score >= ML_RISK_THRESHOLD_HIGH
# MEDIUM risk if score >= ML_RISK_THRESHOLD_MEDIUM
ML_RISK_THRESHOLD_HIGH=0.7
ML_RISK_THRESHOLD_MEDIUM=0.4

# ─── Logging ──────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ─── NASA Worldview (GOES-East IR C13) ───────────────────────────────────────
# Capturas vão para S3; disco local só se NASA_KEEP_LOCAL=true (treino offline)
NASA_CAPTURE_ENABLED=true
NASA_CAPTURES_DIR=data/nasa_captures
NASA_KEEP_LOCAL=false
NASA_HISTORICO_DIAS=30
NASA_S3_PREFIX=nasa-satellite
NASA_CV_S3_PREFIX=screenshots

# ─── External APIs ────────────────────────────────────────────────────────────
# Windy API widget (embedded, no credentials needed)
WINDY_API_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════════
# Notes for AWS Lambda Deployment
# ═══════════════════════════════════════════════════════════════════════════════
#
# 1. In Lambda, use IAM role instead of AWS_ACCESS_KEY_ID/SECRET_ACCESS_KEY
#    - Attach role with DynamoDB, S3, SNS (sns:Publish, sns:Subscribe), CloudWatch Logs permissions
#    - boto3 will auto-detect credentials from role
#
# 2. Pass environment variables via:
#    - AWS Lambda Console → Configuration → Environment variables
#    - SAM template: Globals.Function.Environment
#    - CloudFormation: Properties.Environment
#
# 3. For LocalStack development:
#    AWS_ENDPOINT_URL=http://localhost:4566
#    (Set in boto3.client() calls)
#
# ═══════════════════════════════════════════════════════════════════════════════
