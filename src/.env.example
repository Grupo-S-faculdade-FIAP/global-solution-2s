PROJECT_NAME=
ENVIRONMENT=development

# CORS (separar por vírgula para múltiplas origens)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# AWS Credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_IMAGES=satellite-images-gs2
DYNAMODB_TABLE_IOT=iot
DYNAMODB_TABLE_ALERTS=storm_alerts
# Enquanto AWS não estiver pronta: true = JSON em data/demo/storm_alerts.json
DYNAMODB_USE_MOCK=true
# DYNAMODB_MOCK_STORE_PATH=data/demo/storm_alerts.json
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:<account_id>:rain-alerts

# ML / CV
YOLO_MODEL_PATH=models/yolov5_storm.pt
FIRMS_API_KEY=your_nasa_firms_api_key
