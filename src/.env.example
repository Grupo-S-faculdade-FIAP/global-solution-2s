PROJECT_NAME=Global Solutions — Environmental Intelligence
ENVIRONMENT=development

# CORS (separar por vírgula para múltiplas origens)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# AWS Credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_IMAGES=satellite-images-gs2

# DynamoDB
DYNAMODB_TABLE_ALERTS=alerts
DYNAMODB_IOT_TABLE=iot_readings
# false = DynamoDB AWS real (requer credenciais); true = JSON local em data/demo/
DYNAMODB_USE_MOCK=false
# DYNAMODB_MOCK_STORE_PATH=data/demo/storm_alerts.json  # opcional
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:<account_id>:rain-alerts
SNS_ENABLED=true
SNS_ALERT_SUBJECT=Rain Alert — Storm Detected

# ML / CV
YOLO_CONFIDENCE_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45
YOLO_MODEL_S3_KEY=models/best.pt

# Dashboard
DEMO_MODE=true
MOUNT_DASHBOARD=true
